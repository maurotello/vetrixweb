# HTML — nunca cachear, siempre fresco
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

/en/
  Cache-Control: no-cache, no-store, must-revalidate

/pt/
  Cache-Control: no-cache, no-store, must-revalidate

# CSS y JS versionados — caché agresivo
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes — caché agresivo
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

# Fuentes — caché agresivo
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Webmanifest — caché moderado
/site.webmanifest
  Cache-Control: public, max-age=86400

# Seguridad global
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*; frame-src 'self' https://www.google.com https://wa.me;
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload